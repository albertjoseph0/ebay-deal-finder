# eBay API Credentials
# Get these from https://developer.ebay.com — My Account → Application Keys

# Your App ID (also called Client ID)
EBAY_APP_ID=your-client-id-here

# Your Cert ID (also called Client Secret)
EBAY_CERT_ID=your-client-secret-here

# Set to "true" for sandbox testing, "false" for production
EBAY_SANDBOX=false

# Marketplace (default: EBAY_US)
EBAY_MARKETPLACE_ID=EBAY_US

# ─── Buyer Location (optional — improves shipping cost estimates) ───

# Country code (default: US)
BUYER_COUNTRY=US

# ZIP/postal code — enables accurate CALCULATED shipping estimates
BUYER_POSTAL_CODE=

# ─── Azure OpenAI (optional — enables notebook LLM listing evaluation) ───
# Get these from Azure Portal → your OpenAI resource → Keys and Endpoint

# Your Azure OpenAI resource endpoint (e.g. https://my-resource.openai.azure.com)
AZURE_OPENAI_ENDPOINT=

# API key from Azure Portal
AZURE_OPENAI_API_KEY=

# Deployment name for your model (e.g. gpt-5.4-mini)
AZURE_OPENAI_DEPLOYMENT=
